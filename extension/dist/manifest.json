{
  "manifest_version": 3,
  "name": "ContextCopilot",
  "version": "1.0.0",
  "description": "Ask questions about the current webpage with grounded answers and citations",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "web_accessible_resources": [
    {
      "resources": ["pdfjs/*", "contentScript.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
